{
  "name": "kansaspattons-react-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && vite",
    "build:content": "tsx scripts/build-content.ts",
    "build": "npm run build:content && tsc -b && vite build",
    "publish:content": "npm run build:content && tsx scripts/publish-content.ts",
    "publish:content:dry-run": "npm run build:content && tsx scripts/publish-content.ts --dry-run",
    "api:build": "npm --prefix api run build",
    "api:start": "npm --prefix api start",
    "preview": "vite preview"
  },
  "dependencies": {
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "sanitize-html": "^2.17.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
